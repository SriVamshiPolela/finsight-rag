# Copy to .env and fill in. Never commit .env.

# --- Phase 3: LLM providers ---
LLM_PROVIDER=anthropic      # "anthropic" (default) or "openai"
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
# Optional second provider for the vendor-abstraction swap demo
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Phase 2: vector store ---
VECTOR_STORE=faiss          # "faiss" (dev, default) or "pinecone" (prod path)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=finsight-rag
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# --- Phase 2: experiment tracking ---
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
